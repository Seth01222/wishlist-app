{
  "manifest_version": 3,
  "name": "My Wishlist — Quick Add",
  "version": "1.0.0",
  "description": "Add the product on the current page to your wishlist, with price and image pulled automatically.",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "options_page": "options.html",
  "action": {
    "default_title": "Add to My Wishlist",
    "default_icon": { "192": "icons/icon-192.png" }
  },
  "icons": { "192": "icons/icon-192.png", "512": "icons/icon-512.png" }
}
