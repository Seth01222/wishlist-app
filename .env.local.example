# Copy this file to .env.local and fill in your values.
# Find both under Supabase → Settings → API.

# Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# The "anon" / "public" key (NOT the service_role key — that bypasses RLS and
# must never be exposed to the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ─────────────────────────────────────────────────────────────────────────────
# Not used yet. Per the design (see CLAUDE.md), the SerpAPI and Claude price-
# lookup modes use the user's OWN key, stored per-user in their Supabase profile
# — not a global server env var. These are listed only as a future reference.
# SERPAPI_KEY=
# ANTHROPIC_API_KEY=
